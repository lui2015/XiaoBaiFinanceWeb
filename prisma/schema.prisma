// Prisma schema —— SQLite 版（数据存在本地 xiaobai.db）
// 字段命名采用 camelCase，通过 @map 映射到 snake_case 列名。
// SQLite 不区分 VarChar / TinyInt / MediumText，用通用类型即可。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =======================
// 内容
// =======================
model Category {
  id           BigInt    @id @default(autoincrement())
  parentId     BigInt?   @map("parent_id")
  name         String    
  slug         String    @unique 
  iconUrl      String?   @map("icon_url") 
  sortOrder    Int       @default(0) @map("sort_order")
  status       Int       @default(1)  // 0 停用 1 启用
  description  String?   
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  parent       Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Category[] @relation("CategoryTree")
  articles     Article[]  @relation("CategoryArticles")
  subArticles  Article[]  @relation("SubCategoryArticles")

  @@index([parentId])
  @@index([status, sortOrder])
  @@map("category")
}

model Article {
  id              BigInt    @id @default(autoincrement())
  title           String    
  slug            String    @unique 
  summary         String?   
  sourceType      Int       @default(0) @map("source_type")  // 0 HTML 1 MD 2 在线
  contentMd       String?   @map("content_md") 
  contentHtml     String    @map("content_html") 
  contentText     String    @map("content_text") 
  coverUrl        String?   @map("cover_url") 
  categoryId      BigInt    @map("category_id")
  subCategoryId   BigInt?   @map("sub_category_id")
  status          Int       @default(0)  // 0 草稿 1 已发布 2 已下架
  isRecommend     Boolean   @default(false) @map("is_recommend")
  viewCount       Int       @default(0) @map("view_count")
  likeCount       Int       @default(0) @map("like_count")
  favoriteCount   Int       @default(0) @map("favorite_count")
  authorAdminId   BigInt?   @map("author_admin_id")
  publishAt       DateTime? @map("publish_at")
  scheduledAt     DateTime? @map("scheduled_at") // 定时发布
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  category        Category  @relation("CategoryArticles", fields: [categoryId], references: [id])
  subCategory     Category? @relation("SubCategoryArticles", fields: [subCategoryId], references: [id])
  tags            ArticleTag[]
  favorites       UserFavorite[]
  likes           UserLike[]
  histories       UserHistory[]
  feedbacks       UserFeedback[]

  @@index([status, publishAt])
  @@index([categoryId, status, publishAt])
  @@index([subCategoryId])
  @@index([scheduledAt])
  @@map("article")
}

model Tag {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique 
  slug      String   @unique 
  createdAt DateTime @default(now()) @map("created_at")
  articles  ArticleTag[]
  @@map("tag")
}

model ArticleTag {
  articleId BigInt @map("article_id")
  tagId     BigInt @map("tag_id")
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tag")
}

// =======================
// 账号
// =======================
model AdminUser {
  id            BigInt    @id @default(autoincrement())
  username      String    @unique 
  passwordHash  String    @map("password_hash") 
  realName      String?   @map("real_name") 
  role          Int       @default(1)  // 1 管理员 2 超级管理员
  status        Int       @default(1) 
  failedCount   Int       @default(0) @map("failed_count")
  lockedUntil   DateTime? @map("locked_until")
  lastLoginAt   DateTime? @map("last_login_at")
  lastLoginIp   String?   @map("last_login_ip") 
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  @@map("admin_user")
}

model User {
  id              BigInt    @id @default(autoincrement())
  phoneHash       String?   @unique @map("phone_hash") 
  phoneCipher     String?   @map("phone_cipher") 
  phoneMasked     String?   @map("phone_masked") 
  emailHash       String?   @unique @map("email_hash") 
  emailCipher     String?   @map("email_cipher") 
  emailMasked     String?   @map("email_masked") 
  passwordHash    String?   @map("password_hash") 
  username        String?   @unique  // 账号（用于账号密码登录）
  nickname        String    
  avatarUrl       String?   @map("avatar_url") 
  status          Int       @default(0)  // 0 正常 1 封禁 2 注销中 3 已注销
  isAdmin         Boolean   @default(false) @map("is_admin") // 前台管理员（可进入 /me/manage）
  cancelAt        DateTime? @map("cancel_at")
  registeredAt    DateTime  @default(now()) @map("registered_at")
  lastLoginAt     DateTime? @map("last_login_at")
  lastLoginIp     String?   @map("last_login_ip") 
  failedCount     Int       @default(0) @map("failed_count")
  lockedUntil     DateTime? @map("locked_until")
  // 第三方登录绑定
  wechatOpenid    String?   @unique @map("wechat_openid") 
  wechatUnionid   String?   @map("wechat_unionid") 
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  favorites    UserFavorite[]
  likes        UserLike[]
  histories    UserHistory[]
  feedbacks    UserFeedback[]
  refreshTokens RefreshToken[]
  openApiKeys   OpenApiKey[]

  @@index([status])
  @@map("user")
}

model UserFavorite {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  articleId BigInt   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@unique([userId, articleId])
  @@index([articleId])
  @@map("user_favorite")
}

model UserLike {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  articleId BigInt   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@unique([userId, articleId])
  @@index([articleId])
  @@map("user_like")
}

model UserHistory {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  articleId BigInt   @map("article_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@unique([userId, articleId])
  @@index([userId, viewedAt])
  @@map("user_history")
}

model UserFeedback {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  articleId  BigInt   @map("article_id")
  type       Int       // 0 有用 1 没用 2 报错
  content    String?  
  status     Int      @default(0)  // 0 待处理 1 已采纳 2 已修复 3 已关闭
  handlerId  BigInt?  @map("handler_id")
  handledAt  DateTime? @map("handled_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@index([articleId, type])
  @@index([userId, createdAt])
  @@index([status])
  @@map("user_feedback")
}

// =======================
// 安全 / 审计
// =======================
model SmsLog {
  id        BigInt   @id @default(autoincrement())
  phoneHash String   @map("phone_hash") 
  scene     String   
  codeHash  String   @map("code_hash") 
  ip        String?  
  used      Boolean  @default(false)
  expiredAt DateTime @map("expired_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([phoneHash, createdAt])
  @@map("sms_log")
}

model RefreshToken {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  jti        String   @unique 
  ua         String?  
  ip         String?  
  revoked    Boolean  @default(false)
  expiredAt  DateTime @map("expired_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("refresh_token")
}

model OperationLog {
  id         BigInt   @id @default(autoincrement())
  adminId    BigInt?  @map("admin_id")
  action     String   
  targetType String?  @map("target_type") 
  targetId   String?  @map("target_id") 
  payload    String?   @map("payload") // JSON string stored as text
  ip         String?  
  ua         String?  
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([adminId, createdAt])
  @@map("operation_log")
}

model SearchLog {
  id          BigInt   @id @default(autoincrement())
  keyword     String   
  resultCount Int      @default(0) @map("result_count")
  ip          String?  
  ua          String?  
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([keyword])
  @@index([createdAt])
  @@map("search_log")
}

model ArticleViewLog {
  id        BigInt   @id @default(autoincrement())
  articleId BigInt   @map("article_id")
  userId    BigInt?  @map("user_id")
  ip        String?  
  ua        String?  
  createdAt DateTime @default(now()) @map("created_at")
  @@index([articleId, createdAt])
  @@map("article_view_log")
}

// =======================
// 运营配置
// =======================
model Banner {
  id         BigInt   @id @default(autoincrement())
  title      String   
  imageUrl   String   @map("image_url") 
  linkUrl    String?  @map("link_url") 
  sortOrder  Int      @default(0) @map("sort_order")
  status     Int      @default(1) 
  startAt    DateTime? @map("start_at")
  endAt      DateTime? @map("end_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("banner")
}

model HomeRecommend {
  id        BigInt @id @default(autoincrement())
  articleId BigInt @map("article_id")
  sortOrder Int    @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  @@unique([articleId])
  @@map("home_recommend")
}

model SysConfig {
  k         String   @id 
  v         String   
  remark    String?  
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("sys_config")
}

// =======================
// 开放平台
// =======================
model OpenApiKey {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  // 明文 token 仅在创建时返回一次；库中只存 sha256 哈希，前缀用于界面展示
  keyHash    String   @unique @map("key_hash")
  keyPrefix  String   @map("key_prefix")
  name       String?  // 用户自定义的备注名
  status     Int      @default(1)  // 1 启用 0 停用
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("open_api_key")
}

model OpenApiCallStat {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  date      String   @map("date")  // YYYY-MM-DD（UTC）
  callCount BigInt   @default(0) @map("call_count")
  @@unique([userId, date])
  @@index([userId])
  @@map("open_api_call_stat")
}
