# 应用
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# 数据库（MySQL 8.0+）
DATABASE_URL="mysql://root:root@localhost:3306/xiaobai_finance"

# JWT
JWT_ACCESS_SECRET="please-change-access-secret-min-32-bytes"
JWT_REFRESH_SECRET="please-change-refresh-secret-min-32-bytes"
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=1209600

# AES-GCM (PII 加密；32 bytes base64)
PII_ENC_KEY="REPLACE_WITH_BASE64_32B_KEY"

# 管理员初始账号（仅 seed 使用；seed 时若该 username 已存在则跳过）
SEED_SUPER_ADMIN_USERNAME=admin
SEED_SUPER_ADMIN_PASSWORD=change-me-to-a-strong-password

# 短信服务（腾讯云 SMS）。开发可设 SMS_PROVIDER=mock
SMS_PROVIDER=mock
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# 对象存储（腾讯云 COS）。开发可设 STORAGE_PROVIDER=local
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BASE_URL=

# 搜索：mysql | es
SEARCH_PROVIDER=mysql
ES_NODE=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_INDEX_ARTICLE=xb_article

# 微信开放平台（网页扫码登录，可选）
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=
WECHAT_OPEN_REDIRECT=http://localhost:3000/api/auth/oauth/wechat/callback

# 限流（Redis 可选；不配置则使用进程内令牌桶，仅开发用）
REDIS_URL=
